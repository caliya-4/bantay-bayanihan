# ============================================
# Bantay Bayanihan - .gitignore
# ============================================

# Environment files (NEVER commit these!)
.env
.env.local
.env.production
.env.*.local

# Composer
/vendor/
composer.lock

# IDE and Editor Files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Uploads (user-generated content)
uploads/
uploads/emergency-photos/
uploads/certifications/

# Cache
cache/
*.cache

# Test files (not needed in production)
test-files/
test_api.php

# Database dumps (keep only initial schema)
*.sql.gz
*.sql.bz2
db/*.sql
!db/bantay_bayanihan.sql

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Temporary Files
tmp/
temp/
*.tmp
*.temp

# Backup Files
*.bak
*.backup
*.old

# Sensitive Data
*.key
*.pem
*.cert
*.crt

# Composer PHAR
composer.phar

# Node Modules (if any frontend build tools)
node_modules/
package-lock.json
yarn.lock

# Build output (if any)
dist/
build/

# Debug files
*.debug
debug/
