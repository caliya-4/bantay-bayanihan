# ============================================
# BANTAY BAYANIHAN - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============================================
# Database Configuration (REQUIRED)
# ============================================
DB_HOST=localhost
DB_NAME=bantay_bayanihan
DB_USERNAME=root
DB_PASSWORD='BBs4life!2026'

# ============================================
# Application Settings
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://bantaybayanihan.com
BASE_PATH=C:/xampp/htdocs/cbantay-bayanihan

# ============================================
# Email Configuration (Optional - for drill confirmations)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=noreply@bantaybayanihan.com
SMTP_FROM_NAME=Bantay Bayanihan

# ============================================
# Google Gemini AI (Optional - for chatbot)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Security Settings
# ============================================
# Generate a random string (at least 32 characters)
# You can use: openssl rand -base64 32
APP_SECRET=your_random_secret_key_change_this

# ============================================
# File Upload Settings
# ============================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880
